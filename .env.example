# Public site URL — used to build canonical/OG/sitemap links.
# Set to your deployed URL in production (e.g. https://your-portfolio.com).
NEXT_PUBLIC_APP_URL=

# WhatsApp number for the contact button. International format, digits only.
# Leave empty to hide the WhatsApp channel.
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Search-engine verification (optional).
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_YANDEX_VERIFICATION=
